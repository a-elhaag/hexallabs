# Database (Azure PostgreSQL Flexible Server)
DATABASE_URL=postgresql+asyncpg://Hexallabs:YOUR_PASSWORD@hexallabs-db.postgres.database.azure.com:5432/postgres?ssl=require

# Auth — must match frontend NEXTAUTH_SECRET
JWT_SECRET=your-nextauth-secret-here

# Azure AI Foundry
AZURE_AI_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com/
AZURE_AI_FOUNDRY_KEY=your-foundry-api-key

# Bing Grounding Search
BING_SEARCH_KEY=your-bing-key
