# Anthropic Console (Apex, Pulse)
ANTHROPIC_API_KEY=sk-ant-...

# Azure AI Foundry (Swift, Prism, Depth, Atlas, Horizon, Forge, Spark, Craft, Flux, Bolt)
AZURE_FOUNDRY_ENDPOINT=https://your-endpoint-here
AZURE_FOUNDRY_API_VERSION=2024-10-21
AZURE_FOUNDRY_API_KEY=your-api-key-here

# Tavily (Scout)
TAVILY_API_KEY=tvly-...

# Supabase Auth (JWT verification via JWKS)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Supabase Postgres (use the pooler connection string, not the direct one)
# Format: postgresql+asyncpg://postgres.<project_ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.xxx:password@aws-0-xxx.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# White-label -> real deployment/model
MODEL_APEX=
MODEL_APEX_PROVIDER=

MODEL_PULSE=
MODEL_PULSE_PROVIDER=

MODEL_SWIFT=
MODEL_SWIFT_PROVIDER=

MODEL_PRISM=
MODEL_PRISM_PROVIDER=

MODEL_DEPTH=
MODEL_DEPTH_PROVIDER=

MODEL_ATLAS=
MODEL_ATLAS_PROVIDER=

MODEL_HORIZON=
MODEL_HORIZON_PROVIDER=

MODEL_FORGE=
MODEL_FORGE_PROVIDER=

MODEL_SPARK=
MODEL_SPARK_PROVIDER=

MODEL_CRAFT=
MODEL_CRAFT_PROVIDER=

MODEL_FLUX=
MODEL_FLUX_PROVIDER=

MODEL_BOLT=
MODEL_BOLT_PROVIDER=

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOW_ORIGINS=http://localhost:3000
