# Anthropic Console (Apex, Pulse)
ANTHROPIC_API_KEY=sk-ant-...

# Azure AI Foundry (Swift, Prism, Depth, Atlas, Horizon)
AZURE_FOUNDRY_ENDPOINT=https://your-endpoint-here
AZURE_FOUNDRY_API_VERSION=2024-10-21
AZURE_FOUNDRY_API_KEY=your-api-key-here

# Supabase Auth (JWT verification via JWKS)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Supabase Postgres (use the pooler connection string, not the direct one)
# Format: postgresql+asyncpg://postgres.<project_ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.xxx:password@aws-0-xxx.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# White-label -> real deployment/model
MODEL_APEX=claude-opus-4-7
MODEL_APEX_PROVIDER=anthropic

MODEL_PULSE=claude-sonnet-4-6
MODEL_PULSE_PROVIDER=anthropic

MODEL_SWIFT=gpt-5.4-nano
MODEL_SWIFT_PROVIDER=azure

MODEL_PRISM=grok-4-20-reasoning
MODEL_PRISM_PROVIDER=azure

MODEL_DEPTH=gpt-5.3-chat
MODEL_DEPTH_PROVIDER=azure

MODEL_ATLAS=DeepSeek-V3.2-Speciale
MODEL_ATLAS_PROVIDER=azure

MODEL_HORIZON=Kimi-K2.5
MODEL_HORIZON_PROVIDER=azure
