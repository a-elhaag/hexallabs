          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('jwt_token exists', function () {",
                  "  const t = pm.environment.get('jwt_token');",
                  "  pm.expect(t).to.be.a('string');",
                  "  pm.expect(t.split('.').length).to.eql(3);",
                  "});",
                  "pm.test('expired_jwt_token exists', function () {",
                  "  const t = pm.environment.get('expired_jwt_token');",
                  "  pm.expect(t).to.be.a('string');",
