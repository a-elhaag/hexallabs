{
  "info": {
    "_postman_id": "90d4d5b6-8f6f-4cb8-aea8-6d1bc8a6d3c1",
    "name": "Hexallabs FastAPI - All In One",
    "description": "Single Postman collection with auth token generation, health checks, council API, websocket templates, relay templates, and test UI/SSE endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const useStatic = (pm.environment.get('use_static_dev_token') || 'false').toLowerCase() === 'true';",
          "const staticToken = pm.environment.get('static_dev_token') || '';",
          "if (useStatic && staticToken) {",
          "  pm.environment.set('jwt_token', staticToken);",
          "  return;",
          "}",
          "",
          "const auto = (pm.environment.get('auto_generate_jwt') || 'true').toLowerCase() === 'true';",
          "if (!auto) { return; }",
          "",
          "const secret = pm.environment.get('jwt_secret');",
          "const userId = pm.environment.get('user_id');",
          "const email = pm.environment.get('user_email') || 'postman@hexallabs.local';",
          "const name = pm.environment.get('user_name') || 'Postman Tester';",
          "const ttl = parseInt(pm.environment.get('jwt_ttl_seconds') || '3600', 10);",
          "",
          "if (!secret || !userId) {",
          "  return;",
          "}",
          "",
          "const now = Math.floor(Date.now() / 1000);",
          "const header = { alg: 'HS256', typ: 'JWT' };",
          "const payload = { sub: userId, email, name, exp: now + ttl };",
          "const expiredPayload = { sub: userId, email, name, exp: now - 120 };",
          "",
          "function base64UrlEncodeWordArray(wordArray) {",
          "  return CryptoJS.enc.Base64.stringify(wordArray)",
          "    .replace(/=/g, '')",
          "    .replace(/\\+/g, '-')",
          "    .replace(/\\//g, '_');",
          "}",
          "",
          "function signJwt(pl) {",
          "  const encodedHeader = base64UrlEncodeWordArray(CryptoJS.enc.Utf8.parse(JSON.stringify(header)));",
          "  const encodedPayload = base64UrlEncodeWordArray(CryptoJS.enc.Utf8.parse(JSON.stringify(pl)));",
          "  const signingInput = encodedHeader + '.' + encodedPayload;",
          "  const signature = CryptoJS.HmacSHA256(signingInput, secret);",
          "  const encodedSignature = base64UrlEncodeWordArray(signature);",
          "  return signingInput + '.' + encodedSignature;",
          "}",
          "",
          "pm.environment.set('jwt_token', signJwt(payload));",
          "pm.environment.set('expired_jwt_token', signJwt(expiredPayload));"
        ]
      }
    }
  ],
