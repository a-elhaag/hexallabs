  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const auto = (pm.environment.get('auto_generate_jwt') || 'true').toLowerCase() === 'true';",
          "const current = pm.environment.get('jwt_token');",
          "if (!auto && current) { return; }",
          "",
          "const secret = pm.environment.get('jwt_secret');",
          "const userId = pm.environment.get('user_id') || '00000000-0000-0000-0000-000000000001';",
          "const email = pm.environment.get('user_email') || 'postman@hexallabs.local';",
          "const ttl = parseInt(pm.environment.get('jwt_ttl_seconds') || '3600', 10);",
          "",
          "if (!secret) {",
          "  if (!current) {",
          "    console.warn('JWT not generated: jwt_secret missing and jwt_token not set manually.');",
          "  }",
          "  return;",
          "}",
          "",
          "const now = Math.floor(Date.now() / 1000);",
          "const payload = {",
          "  sub: userId,",
          "  email: email,",
          "  name: pm.environment.get('user_name') || 'Postman Tester',",
          "  exp: now + ttl",
          "};",
          "const header = { alg: 'HS256', typ: 'JWT' };",
          "",
          "function base64UrlEncodeWordArray(wordArray) {",
          "  return CryptoJS.enc.Base64.stringify(wordArray)",
          "    .replace(/=/g, '')",
          "    .replace(/\\+/g, '-')",
          "    .replace(/\\//g, '_');",
          "}",
          "",
          "const encodedHeader = base64UrlEncodeWordArray(CryptoJS.enc.Utf8.parse(JSON.stringify(header)));",
          "const encodedPayload = base64UrlEncodeWordArray(CryptoJS.enc.Utf8.parse(JSON.stringify(payload)));",
          "const signingInput = encodedHeader + '.' + encodedPayload;",
          "const signature = CryptoJS.HmacSHA256(signingInput, secret);",
          "const encodedSignature = base64UrlEncodeWordArray(signature);",
          "const token = signingInput + '.' + encodedSignature;",
          "",
          "pm.environment.set('jwt_token', token);"
        ]
      }
    }
  ],
