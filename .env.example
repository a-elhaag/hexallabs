# Hexallabs — single source of truth for all secrets
# Copy to .env at project root, fill in values.
# Both backend and frontend load from this file.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://Hexallabs:

# ── Auth ───────────────────────────────────────────────────────────────────────
# Shared secret — must match between frontend (AUTH_SECRET) and backend (JWT_SECRET)
AUTH_SECRET=your-nextauth-secret-here
JWT_SECRET=your-nextauth-secret-here

# NextAuth URL (set to deployed URL in production)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secreti

# Azure Email (SMTP) — for email/password auth and transactional email
SMTP_HOST=your-azure-smtp-host.azure.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@hexallabs.com

# ── Azure AI Foundry ───────────────────────────────────────────────────────────
AZURE_AI_FOUNDRY_ENDPOINT=https://hexallabs-ai.services.ai.azure.com/api/projects/hexallabs-project/openai/v1/
AZURE_AI_FOUNDRY_KEY=your-foundry-api-key

# Model deployment names (Azure Foundry deployment names)
MODEL_GPT=gpt-5.1-chat
MODEL_GPT_MINI=gpt-5.4-mini
MODEL_O4_MINI=o4-mini
MODEL_DEEPSEEK=DeepSeek-V3.2-Speciale
MODEL_LLAMA=Llama-3.3-70B-Instruct
MODEL_KIMI=Kimi-K2.5
MODEL_GROK=grok-4-20-reasoning

# ── Tavily Search (Ground Truth feature) ──────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
