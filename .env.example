# Hexallabs — environment variables
# Copy this file to backend/.env and frontend/.env then fill in your secrets.

# ── Shared ────────────────────────────────────────────────────────────────────
# Azure PostgreSQL Flexible Server
DATABASE_URL=postgresql+asyncpg://Hexallabs:YOUR_PASSWORD@hexallabs-db.postgres.database.azure.com:5432/postgres?ssl=require

# ── Backend (backend/.env) ────────────────────────────────────────────────────
# Auth — must match frontend AUTH_SECRET / NEXTAUTH_SECRET
JWT_SECRET=your-nextauth-secret-here

# Azure AI Foundry (OpenAI-compatible endpoint)
AZURE_AI_FOUNDRY_ENDPOINT=https://hexallabs-ai.services.ai.azure.com/api/projects/hexallabs-project/openai/v1/
AZURE_AI_FOUNDRY_KEY=your-foundry-api-key

# Model deployment names
MODEL_GPT=gpt-5.1-chat
MODEL_DEEPSEEK=DeepSeek-V3.2-Speciale
MODEL_LLAMA=Llama-3.3-70B-Instruct
MODEL_KIMI=Kimi-K2.5
MODEL_GROK=grok-4-20-reasoning

# Tavily Search
TAVILY_API_KEY=your-tavily-api-key

# ── Frontend (frontend/.env) ──────────────────────────────────────────────────
# Next Auth — generate with: npx auth secret
AUTH_SECRET=your-nextauth-secret-here

# Discord OAuth provider
AUTH_DISCORD_ID=your-discord-client-id
AUTH_DISCORD_SECRET=your-discord-client-secret

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
