// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
  @@map("posts")
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  emailVerified  DateTime?
  image          String?
  password       String? // null for OAuth users
  accounts       Account[]
  sessions       Session[]
  posts          Post[]
  subscription   Subscription?
  usageLogs      UsageLog[]
  billingEvents  BillingEvent[]
  councilConfigs CouncilConfig[]
  executions     Execution[]

  @@map("users")
}

// ── Billing ────────────────────────────────────────────────────────────────────

model PricingTier {
  id              String         @id @default(cuid())
  name            String         @unique // "core" | "elite" | "arch"
  displayName     String // shown in UI
  monthlyPriceUsd Float // 0 / 15 / 29 ...
  monthlyUsageUsd Float // 5 / 10 / 20 ...
  weeklyUsageUsd  Float // monthlyUsageUsd / 4
  rolloverPct     Float          @default(0.5)
  maxModels       Int // 2 for core, 7 for elite+
  active          Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  subscriptions   Subscription[]

  @@map("pricing_tiers")
}

model Subscription {
  id     String      @id @default(cuid())
  userId String      @unique
  tierId String
  tier   PricingTier @relation(fields: [tierId], references: [id])

  // Monthly tracking
  currentMonthBudgetUsd Float @default(0)
  usedThisMonthUsd      Float @default(0)
  rolloverBalanceUsd    Float @default(0)

  // Weekly tracking
  currentWeekBudgetUsd Float    @default(0)
  usedThisWeekUsd      Float    @default(0)
  weekResetDate        DateTime

  // Stripe
  stripeSubscriptionId String?
  stripeCustomerId     String?
  nextBillingDate      DateTime?
  status               String    @default("active") // active | cancelled | past_due

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageLog {
  id             String   @id @default(cuid())
  userId         String
  executionId    String?
  modelName      String // white-label name (Apex, Swift...)
  deploymentName String // Azure deployment name
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  totalTokens    Int      @default(0)
  ratePerK       Float // COST_PER_1K rate used
  billedUsd      Float // actual amount deducted from budget
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("usage_logs")
}

model BillingEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String // "payment" | "weekly_reset" | "rollover" | "usage_deduction"
  amountUsd Float
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_events")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Council / Execution ────────────────────────────────────────────────────────

model CouncilConfig {
  id             String      @id @default(cuid())
  userId         String      @map("user_id")
  name           String
  models         String[]
  systemPrompt   String      @map("system_prompt")
  organizerModel String?     @map("organizer_model")
  createdAt      DateTime    @default(now()) @map("created_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions     Execution[]

  @@map("council_configs")
}

model Execution {
  id             String        @id @default(cuid())
  councilId      String        @map("council_id")
  userId         String        @map("user_id")
  query          String
  status         String        @default("pending") // pending | running | complete | error
  modelResponses Json?         @map("model_responses")
  peerReviews    Json?         @map("peer_reviews")
  synthesis      String?
  costBreakdown  Json?         @map("cost_breakdown")
  createdAt      DateTime      @default(now()) @map("created_at")
  council        CouncilConfig @relation(fields: [councilId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("executions")
}
